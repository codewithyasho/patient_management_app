# Frontend .gitignore

# System files
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# IDE/Editor
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
.atom/

# Node modules (if using any build tools)
node_modules/
npm-debug.log
yarn-error.log

# Build/Dist files (if using build tools)
dist/
build/
*.min.js
*.min.css

# Package manager lock files (only if using npm/yarn for dev tools)
package-lock.json
yarn.lock

# Temporary files
*.tmp
*.temp
.cache/

# OS backups
*.bak

# Environment files
.env
.env.local
.env.*.local

# IDE temporary files
*.log
